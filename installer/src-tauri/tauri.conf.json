{
  "productName": "DSN Installer",
  "version": "1.0.0",
  "identifier": "com.dsn.installer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DSN Kurulum Sihirbazı",
        "width": 840,
        "height": 560,
        "minWidth": 840,
        "minHeight": 560,
        "resizable": false,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../agent/dist/dsn-agent.exe": "dsn-agent.exe"
    },
    "windows": {
      "nsis": {
        "languages": ["Turkish"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["dsn-agent"]
      }
    }
  }
}
