# Kurulum sihirbazını (Tauri) derlerken gömülür — kopyalayın: copy .env.example .env
# Kendi sunucu IP / alan adınızı yazın.

# Backend API (health, register) — kullanıcı "Sunucu" adımında varsayılan olarak görür
VITE_DEFAULT_DSN_API_URL=https://api.example.com

# Web arayüzü (agent-login sayfası burada; genelde API ile aynı host, port 3000)
VITE_DEFAULT_DSN_WEB_URL=https://example.com
